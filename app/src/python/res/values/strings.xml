<?xml version="1.0" encoding="utf-8"?>
<!--
  Per-flavor launcher label. Python is the reference flavor, so it keeps
  the unadorned "Eridanus" name (matching app/src/main); the kotlin flavor
  is the one marked "(kt)" so the two are tell-apart-able when installed
  side by side (their applicationIds already diverge via
  applicationIdSuffix; this is the cosmetic half).
-->
<resources>
    <string name="app_name">Eridanus</string>
</resources>
