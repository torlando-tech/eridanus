<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="splash_background">#8B6914</color>

    <style name="Theme.Ara" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Ara.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Ara</item>
    </style>
</resources>
