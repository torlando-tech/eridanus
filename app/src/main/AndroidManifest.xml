<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Lets the Battery & Background settings card request a Doze
         exemption (Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS).
         The kotlin flavor also inherits this from rns-android's manifest;
         declaring it here covers the python flavor too. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- The RNS-hosting foreground service (per flavor: rns-android's
         ReticulumService for kotlin, PyReticulumService for python)
         declares its own foregroundServiceType + matching
         FOREGROUND_SERVICE_* permission in the backend module's manifest.
         The app module no longer runs a notification-only service of its
         own. -->

    <application
        android:name="tech.torlando.eridanus.EridanusApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Eridanus">

        <activity
            android:name="tech.torlando.eridanus.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Eridanus.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
